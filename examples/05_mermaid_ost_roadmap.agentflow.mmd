flow analyze_roadmap["Analyze Roadmap"]
      direction TB
      task analyze_roadmap_step1["Step 1"]
        analyze_roadmap_agent_s1["issue_collector"] --- analyze_roadmap_issue_classification_s1["Issue Classification"] --- analyze_roadmap_fetch_issues_s1["fetch_issues"]
        analyze_roadmap_agent_s1 --> analyze_roadmap_issues_s1["issues"]
      end

      task analyze_roadmap_step2["Step 2"]
        analyze_roadmap_agent_s2["issue_collector"] --- analyze_roadmap_issue_classification_s2["Issue Classification"] --- analyze_roadmap_classify_issues_s2["classify_issues"]
        analyze_roadmap_agent_s2 --> analyze_roadmap_classified_s2["classified"]
      end

      task analyze_roadmap_step3["Step 3"]
        analyze_roadmap_agent_s3["persona_analyst"] --- analyze_roadmap_profile_personas_s3["profile_personas"]
        analyze_roadmap_agent_s3 --> analyze_roadmap_personas_s3["personas"]
      end

      task analyze_roadmap_step4["Step 4"]
        analyze_roadmap_agent_s4["theme_analyst"] --- analyze_roadmap_theme_deep_dive_s4["Theme Deep Dive"] --- analyze_roadmap_cluster_themes_s4["cluster_themes"]
        analyze_roadmap_agent_s4 --> analyze_roadmap_themes_s4["themes"]
      end

      task analyze_roadmap_step5["Step 5"]
        analyze_roadmap_agent_s5["strategist"] --- analyze_roadmap_score_impact_s5["score_impact"]
        analyze_roadmap_agent_s5 --> analyze_roadmap_roadmap_s5["roadmap"]
      end

      task analyze_roadmap_step6["Step 6"]
        analyze_roadmap_agent_s6["theme_analyst"] --- analyze_roadmap_find_cross_cutting_s6["find_cross_cutting"]
        analyze_roadmap_agent_s6 --> analyze_roadmap_patterns_s6["patterns"]
      end

      task analyze_roadmap_step7["Step 7"]
        analyze_roadmap_agent_s7["strategist"] --- analyze_roadmap_generate_report_s7["generate_report"]
        analyze_roadmap_agent_s7 --> analyze_roadmap_report_s7["report"]
      end

      task analyze_roadmap_step8["Step 8"]
        analyze_roadmap_agent_s8["archivist"] --- analyze_roadmap_save_report_s8["save_report"]
        analyze_roadmap_agent_s8 --> analyze_roadmap_saved_s8["saved"]
      end

    analyze_roadmap_step1 -->|"issues"| analyze_roadmap_step2
    analyze_roadmap_step2 -->|"classified"| analyze_roadmap_step3
    analyze_roadmap_step3 -->|"personas"| analyze_roadmap_step4
    analyze_roadmap_step4 -->|"themes"| analyze_roadmap_step5
    analyze_roadmap_step5 -->|"roadmap"| analyze_roadmap_step6
    analyze_roadmap_step6 -->|"patterns"| analyze_roadmap_step7
    analyze_roadmap_step7 -->|"report"| analyze_roadmap_step8
    analyze_roadmap_step3 -->|"classified"| analyze_roadmap_step4
    analyze_roadmap_step4 -->|"personas"| analyze_roadmap_step5
    analyze_roadmap_step5 -->|"themes"| analyze_roadmap_step6
    analyze_roadmap_step5 -->|"classified"| analyze_roadmap_step6
    analyze_roadmap_step6 -->|"personas"| analyze_roadmap_step7
    analyze_roadmap_step6 -->|"themes"| analyze_roadmap_step7
    analyze_roadmap_step6 -->|"roadmap"| analyze_roadmap_step7
end
  analyze_roadmap@{
    params: "repo: String"
    returns: "String"
  }
