---
title: Website Builder — Bilingual Coffee Shop Site
config:
  layout: elk
---
agentflow TB

    %% ── Type Declarations ──────────────────────────────────────────
    type SiteConfig = Record {
        name: String
        summary: String
        location: String
    }

    %% ── Templates ───────────────────────────────────────────────────
    %% First-class template blocks (no % prefix in agentflow spec).
    %% Fields carry type, optional multiplier (* N), and description.

    template website_copy {
        HERO_TAGLINE: String           <<one powerful headline>>
        HERO_SUBTITLE: String          <<one compelling subtitle>>
        ABOUT: String                  <<two paragraphs about the coffee shop>>
        MENU_ITEM: String * 6          <<Name | Price | Description>>
        section ENGLISH
    }

    template bilingual {
        section ENGLISH
        section SWEDISH
    }

    %% ── Directives ──────────────────────────────────────────────────
    %% Shape: trapezoid
    %% Composable prompt blocks with typed defaults.

    scandinavian_design[/"Scandinavian Design"/]@{
        text: "DESIGN: Use Google Fonts ({heading_font} for headings, {body_font} for body). Rich color palette matching a Scandinavian coffee brand — deep espresso browns, warm creams, muted sage greens, and golden amber accents. Use CSS custom properties for theming. When switching to Swedish, subtly shift the color palette to cooler Nordic tones (slate blue accents, softer whites)."
        Params:
            heading_font: "String = Playfair Display"
            body_font: "String = Inter"
    }

    glassmorphism_layout[/"Glassmorphism Layout"/]@{
        text: "LAYOUT: Fixed glassmorphism navbar with backdrop-filter blur. Full-viewport hero with parallax scrolling effect. Menu section as a CSS Grid with hover card animations. About section with a split layout. Contact form with floating labels. Sticky footer with {footer_text}."
        Params:
            footer_text: "String = Made with love by PACT"
    }

    scroll_animations[/"Scroll Animations"/]@{
        text: "ANIMATIONS: Use CSS @keyframes and IntersectionObserver for scroll-triggered fade-in-up animations on every section. Hero title should have a typewriter reveal effect. Menu cards should stagger their entrance. Smooth parallax on scroll. Language toggle should animate with a slide transition — cross-fade the content."
    }

    bilingual_toggle[/"Bilingual Toggle"/]@{
        text: "LANGUAGE TOGGLE: Prominent {lang_a}/{lang_b} pill toggle in the navbar. Use data-{lang_a} and data-{lang_b} attributes. When switching languages, cross-fade all text with a 300ms opacity transition. Shift accent colors to Nordic palette in {lang_b} mode."
        Params:
            lang_a: "String = en"
            lang_b: "String = sv"
    }

    %% ── Agents ──────────────────────────────────────────────────────
    %% New spec: `agent id["Label"]...end` with deferred metadata.

    agent researcher["Researcher"]
        research_location
        write_copy
    end
    researcher@{
        permits: "net.read, llm.query"
        prompt: "You are a market research specialist and copywriter. When given a tool result, use the information to produce real output — never describe what you did, just deliver the content."
    }

    agent translator["Translator"]
        translate_to_swedish
    end
    translator@{
        permits: "llm.query"
        prompt: "You are a native Swedish translator specializing in marketing and hospitality. Use du-form. Adapt idioms naturally."
    }

    agent designer["Designer"]
        generate_html
    end
    designer@{
        permits: "llm.query"
        prompt: "You are a senior frontend developer and UI designer. You write production-quality HTML/CSS/JS. Never output markdown — only raw HTML."
    }

    %% ── Agent Bundle ────────────────────────────────────────────────

    agent website_team["Website Team"]
        researcher
        translator
        designer
    end
    website_team@{
        view: collapsed
    }

    %% ── Flow ────────────────────────────────────────────────────────

    flow build_bilingual_site["Build Bilingual Site"]
        direction TB

        task Step1
            direction TB
            aResearcher{{researcher}}@{ agent: researcher } --- research_location@{ shape: subroutine }
            aResearcher --o research@{ shape: doc }
        end

        task Step2
            direction TB
            aResearcher2{{researcher}}@{ agent: researcher } --- write_copy@{ shape: subroutine }
            aResearcher2 --o english_copy@{ shape: doc }
        end

        task Step3
            direction TB
            aTranslator{{translator}}@{ agent: translator } --- translate_to_swedish@{ shape: subroutine }
            aTranslator --o swedish_copy@{ shape: doc }
        end

        task Step4
            direction TB
            aDesigner{{designer}}@{ agent: designer } --- generate_html@{ shape: subroutine }
            aDesigner --o html@{ shape: doc }
        end

        Step1 -->|"research"| Step2
        Step2 -->|"english_copy"| Step3
        Step3 -->|"swedish_copy"| Step4
    end
    build_bilingual_site@{
        params: "request: String"
        returns: "String"
    }

    %% ── Reference Edges ─────────────────────────────────────────────
    %% Output bindings and directive references.

    write_copy --o website_copy
    translate_to_swedish --o bilingual

    generate_html --- scandinavian_design
    generate_html --- glassmorphism_layout
    generate_html --- scroll_animations
    generate_html --- bilingual_toggle

%% ── Deferred node metadata ──
research_location@{ shape: subroutine, requires: "^net.read", returns: "String" }
write_copy@{ shape: subroutine, requires: "^llm.query", returns: "String" }
translate_to_swedish@{ shape: subroutine, requires: "^llm.query", returns: "String" }
generate_html@{ shape: subroutine, requires: "^llm.query", returns: "String" }
