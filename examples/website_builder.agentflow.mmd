agentflow TB
group apa[" "]

agent website_team["Website Team"]

    agent researcher["Researcher"]
        research_location
        write_copy
    end
    researcher@{
        permits: "net.read, llm.query"
        prompt: "You are a market research specialist and copywriter. When given a tool result, use the information to produce real output — never describe what you did, just deliver the content. When writing copy, write the actual words that will appear on the website. Be creative, specific, and evocative. Reference the local area by name."
    }

    agent translator["Translator"]
        translate_to_swedish
    end
    translator@{
        permits: "llm.query"
        prompt: "You are a native Swedish translator specializing in marketing and hospitality. When you receive English copy, immediately translate it. Never describe what you are doing — just output the bilingual content in the exact format requested by the tool. Use du-form. Adapt idioms naturally."
    }

    agent designer["Designer"]
        generate_html
    end
    designer@{
        permits: "llm.query"
        prompt: "You are a senior frontend developer and UI designer at a top creative agency. You obsess over typography, whitespace, micro-interactions, and visual hierarchy. Your websites win Awwwards. You write production-quality HTML/CSS/JS with no shortcuts. You use modern CSS (grid, custom properties, clamp(), backdrop-filter, scroll-behavior). You implement smooth scroll-triggered animations with IntersectionObserver. You never use placeholder images — instead you create beautiful SVG illustrations or CSS art. Your designs feel premium, editorial, and alive. Never output markdown — only raw HTML."
    }
  end
  website_team@{
    view: collapsed
}
end
group other[" "]

directive scandinavian_design["Scandinavian Design"]
  body_font["body_font: String = Inter"]
  heading_font["heading_font: String = Playfair Display"]
end
scandinavian_design@{ params: "body_font :: String = Inter, heading_font :: String = Playfair Display" }

directive glassmorphism_layout["Glassmorphism Layout"]
  footer_text["footer_text: String = Made with love by PACT"]
end
glassmorphism_layout@{ params: "footer_text :: String = Made with love by PACT" }

scroll_animations["Scroll Animations"]
scroll_animations@{ shape: trapezoid }

directive bilingual_toggle["Bilingual Toggle"]
  lang_a["lang_a: String = en"]
  lang_b["lang_b: String = sv"]
end
bilingual_toggle@{ params: "lang_a :: String = en, lang_b :: String = sv" }
end
other@{algorithm: elk.box}
group permissions[" "]
  net{{net}}
  llm{{llm}}
  llm -->> llm_query
  net -->> net_read
end
permissions@{algorithm: elk.layered}

flow build_bilingual_site["Build Bilingual Site"]
      direction TB
      task build_bilingual_site_step1["Step 1"]
        build_bilingual_site_agent_s1["researcher"] --- build_bilingual_site_research_location_s1["research_location"]
        build_bilingual_site_agent_s1 --> build_bilingual_site_research_s1["research"]
      end

      task build_bilingual_site_step2["Step 2"]
        build_bilingual_site_agent_s2["researcher"] --- build_bilingual_site_write_copy_s2["write_copy"]
        build_bilingual_site_agent_s2 --> build_bilingual_site_english_copy_s2["english_copy"]
      end

      task build_bilingual_site_step3["Step 3"]
        build_bilingual_site_agent_s3["translator"] --- build_bilingual_site_translate_to_swedish_s3["translate_to_swedish"]
        build_bilingual_site_agent_s3 --> build_bilingual_site_swedish_copy_s3["swedish_copy"]
      end

      task build_bilingual_site_step4["Step 4"]
        build_bilingual_site_agent_s4["designer"] --- build_bilingual_site_generate_html_s4["generate_html"]
        build_bilingual_site_agent_s4 --> build_bilingual_site_html_s4["html"]
      end

    build_bilingual_site_step1 -->|"research"| build_bilingual_site_step2
    build_bilingual_site_step2 -->|"english_copy"| build_bilingual_site_step3
    build_bilingual_site_step3 -->|"swedish_copy"| build_bilingual_site_step4
end
  build_bilingual_site@{
    params: "request: String"
    returns: "String"
  }
build_bilingual_site_agent_s1@{ def: researcher, shape: tag-rect }
build_bilingual_site_research_location_s1@{ shape: subroutine }
build_bilingual_site_research_s1@{ shape: doc }
build_bilingual_site_agent_s2@{ def: researcher, shape: tag-rect }
build_bilingual_site_write_copy_s2@{ shape: subroutine }
build_bilingual_site_english_copy_s2@{ shape: doc }
build_bilingual_site_agent_s3@{ def: translator, shape: tag-rect }
build_bilingual_site_translate_to_swedish_s3@{ shape: subroutine }
build_bilingual_site_swedish_copy_s3@{ shape: doc }
build_bilingual_site_agent_s4@{ def: designer, shape: tag-rect }
build_bilingual_site_generate_html_s4@{ shape: subroutine }
build_bilingual_site_html_s4@{ shape: doc }

template website_copy {
    HERO_TAGLINE: String           <<one powerful headline>>
    HERO_SUBTITLE: String           <<one compelling subtitle>>
    ABOUT: String           <<two paragraphs about the coffee shop, its story, values>>
    MENU_ITEM: String * 6           <<Name | Price | Description>>
  }

template bilingual {
    section ENGLISH           <<paste the original English copy exactly as received>>
    section SWEDISH           <<translate every line to Swedish, keep section labels unchanged>>
  }

